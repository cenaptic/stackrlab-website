---
import Layout from '../layouts/Layout.astro';
---
<Layout title="STACKr Lab" description="STACKr Lab — coming soon.">
  <main>
    <section>
      <h1>STACKr Lab</h1>
      <p>Coming soon.</p>
    </section>
  </main>
</Layout>

<style>
  main {
    min-height: 100dvh;
    display: grid;
    place-items: center;
    padding: 2rem;
  }
  section {
    text-align: center;
    max-width: 32rem;
  }
  h1 {
    font-size: clamp(2.5rem, 8vw, 4.5rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    margin: 0 0 0.5rem;
  }
  p {
    color: var(--muted);
    font-size: 1.125rem;
    margin: 0;
  }
</style>
